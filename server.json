{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.panellatech/panella",
  "title": "Panella",
  "description": "Governed, self-hosted memory for AI agents: writes queue until an authorized approver signs off.",
  "websiteUrl": "https://panella.tech",
  "repository": {
    "url": "https://github.com/panellatech/panella",
    "source": "github"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "panella",
      "version": "0.2.1",
      "runtimeHint": "uvx",
      "packageArguments": [
        { "type": "positional", "value": "up" },
        { "type": "named", "name": "--yes" }
      ],
      "transport": {
        "type": "streamable-http",
        "url": "http://127.0.0.1:8001/mcp"
      }
    }
  ]
}
