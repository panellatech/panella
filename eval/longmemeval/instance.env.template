# Env template for the isolated eval box (`make eval-up`). Copy to a private file if you want to
# hand-tune it; `make eval-*` targets already source eval/out/state.env (written by eval-up) so
# most runs need no manual copy. NEVER point these at a real/production box.
#
# Store lane (also the bulk-ingest path for BOTH lanes — see eval/README.md):
PANELLA_EVAL_STORE_URL=http://127.0.0.1:18000
PANELLA_EVAL_API_KEY=    # the eval box's PANELLA_API_KEY (eval/out/compose.env; NOT a real box's key)

# Facade lane (the governed path a real user runs):
PANELLA_EVAL_FACADE_URL=http://127.0.0.1:18001
PANELLA_EVAL_BEARER=    # an owner bearer minted via `make eval-up` (eval/out/state.env)

# Dataset:
PANELLA_EVAL_DATA=longmemeval_s_cleaned.json

# QA-accuracy scoring (either set OPENAI_API_KEY, or pass --reader-transport/--judge-transport codex
# to eval/longmemeval/qa.py to use a local `codex` CLI subprocess instead):
OPENAI_API_KEY=
